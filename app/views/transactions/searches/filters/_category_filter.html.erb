<%# locals: (form:) %>
<div data-controller="list-filter">
  <div class="relative">
    <input type="search" autocomplete="off" placeholder="<%= t("transactions.search.filters.placeholders.categories") %>" data-list-filter-target="input" data-action="input->list-filter#filter" class="block w-full bg-container border border-secondary rounded-md py-2 pl-10 pr-3 focus:ring-gray-500 sm:text-sm">
    <%= icon("search", class: "absolute inset-y-0 left-2 top-1/2 transform -translate-y-1/2") %>
  </div>
  <div class="my-2" id="list" data-list-filter-target="list">
    <% family_categories.each do |category| %>
      <% display_name = category.respond_to?(:name_with_parent) ? category.name_with_parent : category.name %>
      <% display_category = category.dup %>
      <% display_category.name = display_name %>
      <% filter_value = category.persisted? ? category.id : Category::UNCATEGORIZED_FILTER_TOKEN %>
      <div class="filterable-item flex items-center gap-2 p-2" data-filter-name="<%= display_name %>">
        <%= form.check_box :category_ids,
                           {
                             multiple: true,
                             checked: @q[:category_ids]&.map(&:to_s)&.include?(filter_value.to_s),
                             class: "checkbox checkbox--light"
                           },
                           filter_value,
                           nil %>
        <%= form.label :category_ids, filter_value, value: filter_value, class: "text-sm text-primary cursor-pointer" do %>
          <%= render partial: "categories/badge", locals: { category: display_category } %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
